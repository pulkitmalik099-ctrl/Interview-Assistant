# Gemini API Key (get from https://aistudio.google.com/)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Audio Threshold (adjust based on noise level, e.g. 0.01 to 0.05)
AUDIO_THRESHOLD=0.015

# Silence Timeout (in seconds) - duration of silence required to trigger answer generation
SILENCE_DURATION=2.0

# Optional: Audio Device Name or ID to use. If empty or None, uses default input device.
# Run with python interview_assistant.py --list-devices to see all device IDs.
AUDIO_DEVICE_ID=None
